# Environment variables
# Copy this to .env and fill in your keys

# GNews API (optional, for recent news)
# Get free key at: https://gnews.io/
GNEWS_API_KEY=

# NewsAPI (optional, for recent news)
# Get free key at: https://newsapi.org/
NEWSAPI_KEY=

# Google Cloud Project (optional, for GDELT BigQuery)
# Only needed if using BigQuery instead of GDELT DOC API
GOOGLE_CLOUD_PROJECT=
